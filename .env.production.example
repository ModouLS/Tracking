# Copy these into Railway → Service → Variables
# Generate a strong SESSION_SECRET with: openssl rand -hex 32

SESSION_SECRET=REPLACE_WITH_STRONG_SECRET_32_CHARS_MIN

# Railway persistent volume must be mounted at /data
# Set this in Railway: Service → Settings → Volumes → Mount path: /data
DATA_DIR=/data

CACHE_TTL_MINUTES=15

NEXT_PUBLIC_SUPPORT_EMAIL=support@kinsing.de
NEXT_PUBLIC_SUPPORT_PHONE=+49 30 1234567
