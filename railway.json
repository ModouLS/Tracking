{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "cronJobs": [
      {
        "schedule": "*/15 * * * *",
        "command": "curl -s -X POST http://localhost:$PORT/api/refresh -H \"Authorization: Bearer $CRON_SECRET\""
      }
    ]
  }
}
